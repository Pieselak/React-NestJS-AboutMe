{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build",
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://pieselak.app/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
